# ==========================================
# PHẦN 1: CẤU HÌNH BẮT BUỘC CHỈ ĐỂ CHẠY BOT
# ==========================================

# Mật khẩu quản lý bot Telegram (Lấy từ @BotFather)
TELEGRAM_BOT_TOKEN=your_bot_token_here

# URI Kết nối MongoDB Atlas (Tùy chọn, thêm vào để lưu trữ Hybrid Cloud Storage)
MONGODB_URI=mongodb+srv://user:pass@cluster.mongodb.net/?retryWrites=true&w=majority

# Đồng bộ MongoDB:
# - auto: Windows = pull-only, Linux = push
# - push: cho phép ghi cloud
# - pull: chỉ đọc cloud khi local trống, không ghi ngược lên
# - off: tắt hẳn sync cloud
MONGODB_SYNC_MODE=auto

# Tùy chọn: chỉ hostname này mới được phép push lên cloud.
# Dùng để khóa chỉ VPS được ghi, local dev sẽ không ghi đè cloud prod.
MONGODB_SYNC_WRITER_HOSTNAME=

# ======================================================================
# HƯỚNG DẪN TẠO GITHUB_TOKEN BẰNG PAT (Fine-grained Personal Access Token)
# ======================================================================
# 1. Truy cập link: https://github.com/settings/personal-access-tokens/new
# 2. Đặt tên (Token name), Hạn sử dụng (Expiration).
# 3. Mục "Repository access": Chọn "All repositories" (hoặc "Only select repositories" rồi chọn repo Kernel).
# 4. Mục "Permissions" -> "Repository permissions" -> Cấp quyền "Read and write" cho TẤT CẢ TÍNH NĂNG "Actions", "Contents".
# 5. Cuối cùng bấm "Generate token" màu xanh lá cây và copy mã `github_pat_...` dán vào dưới đây.
# ======================================================================
#GITHUB_TOKEN=github_pat_xxxx
GITHUB_TOKEN=github_pat_xxxx
GITHUB_OWNER=your_github_username

# Tên kho chứa Kernel (Repository) và nhánh mặc định
GKI_REPO=GKI_KernelSU_SUSFS
GKI_DEFAULT_BRANCH=dev

# Tên kho chứa OnePlus Kernel (Dành cho lệnh /oki)
# Hãy rẽ nhánh (fork) repo Numbersf/Action-Build về Github cá nhân trước khi dùng
OKI_REPO=Action-Build
OKI_DEFAULT_BRANCH=SukiSU-Ultra
OKI_WORKFLOW=Build Kernel OnePlus.yml

# ID Telegram của bạn (Lấy từ @userinfobot) - Quyền quản trị tối cao (Chỉ nhận 1 ID)
OWNER_ID=123456789

# ==========================================
# KHU VỰC DÀNH CHO VPS: CẤU HÌNH GITHUB ACTIONS RUNNER
# ==========================================
# Token tạo VPS Runner mới (Lấy từ Settings -> Actions -> Runners -> New self-hosted runner)
GITHUB_RUNNER_TOKEN=

# HỖ TRỢ QUẢN TRỊ VIÊN: Các ID phụ tá (Phân cách bằng dấu phẩy, để trống nếu không có)
ADMIN_IDS=

# ------------------------------------------
# CẤU HÌNH RIÊNG CHO USERBOT (TÙY CHỌN BAO GỒM STRING SESSION)
# Lấy API từ my.telegram.org (Bắt buộc nếu dùng userbot)
TELEGRAM_API_ID=
TELEGRAM_API_HASH=

# Khóa String Session (String ảo cấp quyền Telethon, bỏ dùng file .session do bảo mật/bất tiện)
TELEGRAM_STRING_SESSION=your_generated_string_session_here

# Chế độ khởi chạy riêng lẻ của Userbot (1 = Chạy độc lập tự get logs, Để trống = Chạy kèm bot)
USERBOT_STANDALONE=1

# Giới hạn ID nhóm chat được phép gọi Userbot (Ví dụ: -100123,-100456)
USERBOT_ALLOWED_CHAT_IDS=
