# === Telegram ===
TELEGRAM_BOT_TOKEN=your_bot_token_here

# === GitHub ===
# Fine-grained PAT: Settings > Developer settings > Personal access tokens > Fine-grained tokens
# Permission cần: Actions (Read and Write)
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
GITHUB_OWNER=your_github_username

# === GKI Repo ===
GKI_REPO=your_gki_repo_name
GKI_DEFAULT_BRANCH=main
# Format: TenHienThi=workflow_file.yml, phân cách bằng dấu phẩy
GKI_WORKFLOWS=Build=build.yml,Release=test_release.yml

# === Permissions ===
# Owner: quyền cao nhất (duy nhất 1 người)
OWNER_ID=123456789
# Admins: quyền quản lý build, nhiều người, phân cách bằng dấu phẩy (để trống nếu chưa có)
ADMIN_IDS=

# === Telegram User Mode (optional) ===
# Dung cho user account mode (Telethon), khong can neu chi chay bot mode.
TELEGRAM_API_ID=
TELEGRAM_API_HASH=
TELEGRAM_SESSION=gki_user
# Gioi han chat cho phep chay lenh tren user mode, vi du: -100123,-100456
USERBOT_ALLOWED_CHAT_IDS=
# Bat standalone mode (userbot tu poll va thong bao, khong can bot chay cung)
# Dat thanh 1 neu chi chay userbot, de trong neu chay cung bot
USERBOT_STANDALONE=1
